{
  "name": "circle-interactive/civicrm-api",
  "type": "library",
  "description": "Fork of circle-interactive/civicrm-api — replaced laminas-diactoros with guzzlehttp/psr7 for PHP 8.2+ compatibility.",
  "keywords": ["civicrm", "remote api library", "developer api"],
  "homepage": "https://github.com/cheveuxroux69/civicrm-api",
  "license": "AGPL-3.0",
  "authors": [
    {
      "name": "Matt Trim",
      "email": "matt@circle-interactive.co.uk",
      "homepage": "https://www.circle-interactive.co.uk",
      "role": "Original author"
    },
    {
      "name": "Piers G",
      "role": "Fork maintainer"
    }
  ],
  "support": {
    "docs": "https://github.com/cheveuxroux69/civicrm-api",
    "issues": "https://github.com/cheveuxroux69/civicrm-api/issues",
    "source": "https://github.com/cheveuxroux69/civicrm-api"
  },
  "require": {
    "php": "^8.2",
    "ext-json": "*",
    "guzzlehttp/psr7": "^2.9",
    "psr/http-client": "^1.0.3",
    "psr/http-message": "^2.0"
  },
  "require-dev": {
    "guzzlehttp/guzzle": "^7.10",
    "nyholm/psr7": "^1.8",
    "pestphp/pest": "^1.23",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^9",
    "squizlabs/php_codesniffer": "*"
  },
  "autoload": {
    "psr-4": {
      "Circle\\CiviCRM\\": "CiviCRM"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Circle\\CiviCRM\\Tests\\": "tests"
    }
  },
  "scripts": {
    "test": [
      "@pest",
      "@phpstan",
      "@phpcs"
    ],
    "pest": "pest",
    "phpstan": "phpstan analyse CiviCRM tests --memory-limit=-1",
    "phpcs": "vendor/bin/phpcs --standard=PSR12 CiviCRM"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
